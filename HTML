<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>senna. 🌿</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Nunito:ital,wght@0,400;0,600;0,700;0,800;0,900;1,400&family=Gaegu:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
</head>
<body>

<!-- Floating decorative blobs -->
<div class="blob blob-1"></div>
<div class="blob blob-2"></div>
<div class="blob blob-3"></div>

<!-- ===== BERANDA ===== -->
<div class="page active" id="page-beranda">
    <div class="beranda-wrap">

        <!-- Header -->
        <header class="site-header">
            <div class="logo-area">
                <span class="logo-duck">🦆</span>
                <span class="logo-text">Senna.</span>
            </div>
            <div class="header-time" id="headerTime"></div>
        </header>

        <!-- Mini player bar -->
        <div class="now-bar" id="nowBar">
            <div class="now-bar-wave" id="nowBarWave">
                <span></span><span></span><span></span><span></span><span></span>
                <span></span><span></span><span></span><span></span><span></span>
            </div>
            <div class="now-bar-info">
                <span class="now-bar-title" id="nowBarTitle">Iris</span>
                <span class="now-bar-dot">·</span>
                <span class="now-bar-artist" id="nowBarArtist">Goo Goo Dolls</span>
            </div>
            <button class="now-bar-play" id="nowBarPlay" onclick="togglePlay()">▶</button>
        </div>

        <!-- App grid -->
        <div class="app-grid">

            <div class="app-card card-music" onclick="openPage('music')" data-label="Music">
                <div class="card-inner">
                    <div class="card-emoji">🐸</div>
                    <div class="card-ripple"></div>
                </div>
                <span class="card-label">Music</span>
            </div>

            <div class="app-card card-note" onclick="openPage('hsk')" data-label="Note">
                <div class="card-inner">
                    <div class="card-emoji">🐌</div>
                    <div class="card-ripple"></div>
                </div>
                <span class="card-label">Note</span>
            </div>

            <div class="app-card card-anime" onclick="openPage('anime')" data-label="My Fav Anime">
                <div class="card-inner">
                    <div class="card-emoji">🌸</div>
                    <div class="card-ripple"></div>
                </div>
                <span class="card-label">My Fav Anime</span>
            </div>

            <div class="app-card card-about" onclick="openAbout()" data-label="About ME">
                <div class="card-inner">
                    <div class="card-emoji">🐥</div>
                    <div class="card-ripple"></div>
                </div>
                <span class="card-label">About ME</span>
            </div>

            <div class="app-card card-quiz" onclick="openPage('quiz')" data-label="Quiz 汉字" style="grid-column: 1 / -1;">
                <div class="card-inner">
                    <div style="display:flex;align-items:center;gap:12px;">
                        <div class="card-emoji">🧠</div>
                        <div class="card-label" style="font-size:1.15rem;">Quiz 汉字</div>
                        <div style="font-size:0.75rem;color:var(--text-soft);margin-top:2px;">HSK 4–5 · </div>
                    </div>
                </div>
                <div class="quiz-card-stats">
                    <span class="qcs-item" id="cardStreak">🔥 0</span>
                    <span class="qcs-item" id="cardXP">⭐ 0 XP</span>
                </div>
                <div class="card-ripple"></div>
                <span class="card-label" style="display:none;"></span>
            </div>

            <div class="app-card card-kewen" onclick="openPage('kwn')" style="grid-column: 1 / -1;">
                <div class="card-inner" style="flex-direction:row; justify-content:flex-start; padding:0 8px; gap:12px;">
                    <div class="card-emoji">🐥</div>
                    <div>
                        <div class="card-label" style="font-size: 1.1em;">课文</div>
                        <div style="font-size:0.75rem;color:var(--text-soft);margin-top:2px;">teks pelajaran mandarin</div>
                    </div>
                    <div class="card-ripple"></div>
                </div>
                <span class="card-label" style="display:none;"></span>
            </div>

        </div>

        <!-- Greeting bubble -->
        <div class="greeting-bubble">
            <span class="bubble-text">haii~  alwyshappy ✿</span>
        </div>

    </div>
</div>

<!-- ===== MUSIC PAGE (PANEL SLIDE) ===== -->
<div class="side-panel" id="panel-music">
    <div class="panel-header">
        <button class="panel-back" onclick="closePanel('music')">← kembali</button>
        <h2 class="panel-title">🎵 music</h2>
    </div>

    <div class="music-layout">
        <!-- Playlist kiri -->
        <div class="playlist-section">
            <div class="playlist-header">
                <span class="playlist-title-text">playlist</span>
                <span class="playlist-stats" id="playlistStats">loading...</span>
            </div>
            <div class="playlist-container" id="playlistContainer"></div>
            <div class="playlist-actions">
                <button class="action-pill" id="shuffleBtn" onclick="toggleShuffle()">🔀 shuffle</button>
                <button class="action-pill" id="repeatBtn" onclick="toggleRepeat()">🔁 repeat</button>
            </div>
        </div>

        <!-- Player kanan -->
        <div class="player-section">
            <div class="vinyl-wrap">
                <div class="vinyl" id="vinylRecord">
                    <div class="vinyl-label">
                        <img src="" alt="cover" id="nowPlayingCover" class="vinyl-cover">
                    </div>
                    <div class="vinyl-groove g1"></div>
                    <div class="vinyl-groove g2"></div>
                    <div class="vinyl-groove g3"></div>
                    <div class="vinyl-hole"></div>
                </div>
                <div class="vinyl-shadow"></div>
            </div>

            <div class="track-info" id="eqWrapper">
                <div class="eq-row">
                    <span class="eq-badge">NOW PLAYING</span>
                    <div class="eq-bars" id="eqBars">
                        <span></span><span></span><span></span><span></span><span></span>
                    </div>
                </div>
                <h3 class="track-name" id="nowPlayingTitle">Iris</h3>
                <p class="track-artist-name" id="nowPlayingArtist">Goo Goo Dolls</p>
                <p class="track-album-name" id="nowPlayingAlbum">Dizzy Up The Girl (1998)</p>
            </div>

            <div class="player-controls">
                <div class="progress-row">
                    <span class="t-stamp" id="currentTime">0:00</span>
                    <div class="progress-track" id="progressBar" onclick="seek(event)">
                        <div class="progress-fill" id="progressFill"></div>
                        <div class="progress-thumb" id="progressThumb"></div>
                    </div>
                    <span class="t-stamp" id="totalTime">0:00</span>
                </div>

                <div class="ctrl-row">
                    <button class="ctrl-btn" onclick="prevTrack()">⏮</button>
                    <button class="ctrl-btn ctrl-play" id="playPauseBtn" onclick="togglePlay()">▶</button>
                    <button class="ctrl-btn" onclick="nextTrack()">⏭</button>
                </div>

                <div class="vol-row">
                    <span id="volumeIcon">🔊</span>
                    <div class="vol-track">
                        <input type="range" id="volumeSlider" min="0" max="1" step="0.01" value="0.7">
                        <div class="vol-fill" id="volumeLevel" style="width:70%"></div>
                    </div>
                    <span class="vol-pct" id="volumePercent">70%</span>
                    <button class="vol-mute" onclick="toggleMute()">
                        <span id="muteIcon">🔇</span>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <audio id="audioPlayer" preload="metadata"></audio>
</div>

<!-- ===== HSK PAGE (PANEL) ===== -->
<div class="side-panel" id="panel-hsk">
    <div class="panel-header">
        <button class="panel-back" onclick="closePanel('hsk')">← kembali</button>
        <h2 class="panel-title">📝 我的笔记</h2>
    </div>
    
    <div class="full-panel">
        <!-- Search box -->
        <div class="search-wrapper">
            <input type="text" class="search-input" id="hskSearch" 
                   placeholder="🔍 cari kata..." oninput="filterHsk()">
        </div>
        
        <!-- Daftar judul (kata HSK) -->
        <div class="lesson-list" id="hskList"></div>
  
        </div>
    </div>
</div>

<!-- ===== KEWEN PAGE (PANEL) ===== -->
<div class="side-panel" id="panel-kwn">
    <div class="panel-header">
        <button class="panel-back" onclick="closePanel('kwn')">← kembali</button>
        <h2 class="panel-title">📝 课文</h2>
    </div>
    
    <div class="full-panel">
        <!-- Search box -->
        <div class="search-wrapper">
            <input type="text" class="search-input" id="kewenSearch" 
                   placeholder="🔍 cari kata dalam课文..." oninput="filterKwn()">
        </div>
        
        <!-- Daftar judul -->
        <div class="lesson-list" id="kwnList"></div>

        </div>
    </div>
</div>

<!-- ===== ANIME PAGE (PANEL) ===== -->
<div class="side-panel" id="panel-anime">
    <div class="panel-header">
        <button class="panel-back" onclick="closePanel('anime')">← kembali</button>
        <h2 class="panel-title">🌸 My Fav Anime</h2>
    </div>
    <div class="anime-grid" id="animeGrid"></div>
</div>

<!-- ===== ABOUT MODAL ===== -->
<div class="modal-bg" id="aboutModal" onclick="closeAboutCheck(event)">
    <div class="about-card">
        <button class="about-close" onclick="closeAbout()">✕</button>
        <div class="about-duck">🐥</div>
        <h2 class="about-name">senna.</h2>
        <p class="about-sub">alwyshappy · 开开心心 🌿</p>
        <div class="about-tags">
            <span class="tag">🎵 musik</span>
            <span class="tag">📖 mandarin</span>
            <span class="tag">🌸 anime</span>
            <span class="tag">🎨 desain</span>
            <span class="tag">🐸 apa aja</span>
        </div>
        <p class="about-bio">haii! aku senna 🦆<br>suka hal-hal yang lucu, dengerin musik or nonton sambil rebahan, dan belajar sambil belajar haha</p>
        <div class="about-socials">
            <a href="#" class="social-pill">ig</a>
            <a href="#" class="social-pill">github</a>
        </div>
    </div>
</div>

<!-- ===== QUIZ PANEL ===== -->
<div class="side-panel" id="panel-quiz">

    <!-- Header -->
    <div class="panel-header">
        <button class="panel-back" onclick="closePanel('quiz'); stopQuiz()">← kembali</button>
        <h2 class="panel-title">🧠 Quiz </h2>
        <div class="quiz-header-stats">
            <span class="qh-pill fire" id="qhStreak">🔥 0</span>
            <span class="qh-pill xp" id="qhXP">⭐ 0 XP</span>
        </div>
    </div>

    <!-- XP + Level bar -->
    <div class="xp-bar-wrap">
        <span class="xp-level" id="xpLevel">Lv.1</span>
        <div class="xp-bar-track">
            <div class="xp-bar-fill" id="xpBarFill" style="width:0%"></div>
            <span class="xp-bar-label" id="xpBarLabel">0 / 100 XP</span>
        </div>
    </div>

    <!-- ── HOME SCREEN ── -->
    <div id="quizHome">

        <div class="quiz-home-hero">
            <div class="qhero-char" id="qheroChar">学</div>
            <div class="qhero-text">
                <p class="qhero-title">HSK 4–5 · Pilihan Ganda</p>
                <p class="qhero-sub">tebak arti & pinyin · 10 soal per sesi</p>
            </div>
        </div>

        <!-- Sub-mode pills: arti vs pinyin vs acak -->
        <div class="quiz-submode-row">
            <button class="submode-pill active" id="sm-both"   onclick="setSubMode('both')">🎲 Acak</button>
            <button class="submode-pill"        id="sm-meaning" onclick="setSubMode('meaning')">🇮🇩 Arti</button>
            <button class="submode-pill"        id="sm-pinyin"  onclick="setSubMode('pinyin')">🔤 Pinyin</button>
        </div>

        <button class="quiz-start-btn" onclick="startQuiz()">
            <span>mulai belajar</span>
            <span class="start-arrow">→</span>
        </button>

        <!-- All-time stats -->
        <div class="quiz-summary-bar">
            <div class="qs-item">
                <span class="qs-num" id="statTotal">0</span>
                <span class="qs-label">dijawab</span>
            </div>
            <div class="qs-div"></div>
            <div class="qs-item">
                <span class="qs-num" id="statCorrect">0</span>
                <span class="qs-label">benar</span>
            </div>
            <div class="qs-div"></div>
            <div class="qs-item">
                <span class="qs-num" id="statAccuracy">0%</span>
                <span class="qs-label">akurasi</span>
            </div>
            <div class="qs-div"></div>
            <div class="qs-item">
                <span class="qs-num" id="statBestStreak">0</span>
                <span class="qs-label">streak 🔥</span>
            </div>
        </div>

    </div>

    <!-- ── QUIZ ARENA ── -->
    <div id="quizArena" style="display:none;">

        <!-- Lives + streak row -->
        <div class="arena-top-row">
            <div class="lives-row" id="livesRow">
                <!-- hearts rendered by JS -->
            </div>
            <div class="arena-streak" id="arenaStreak">🔥 0</div>
        </div>

        <!-- Progress bar (soal) -->
        <div class="quiz-progress-row">
            <div class="quiz-prog-track">
                <div class="quiz-prog-fill" id="quizProgFill" style="width:0%"></div>
            </div>
            <span class="quiz-prog-label" id="quizProgLabel">1 / 10</span>
        </div>

        <!-- Question type badge -->
        <div class="quiz-type-badge" id="quizTypeBadge">tebak artinya</div>

        <!-- Question card -->
        <div class="quiz-q-card" id="quizQCard"></div>

        <!-- 4 options -->
        <div class="mc-options" id="mcOptions"></div>

        <!-- Feedback banner -->
        <div class="quiz-feedback" id="quizFeedback" style="display:none;"></div>

        <!-- Next button -->
        <button class="quiz-next-btn" id="quizNextBtn" onclick="nextQuestion()" style="display:none;">
            soal berikutnya →
        </button>

        <!-- Skip -->
        <button class="quiz-skip-btn" id="quizSkipBtn" onclick="skipQuestion()">lewati</button>

    </div>

    <!-- ── RESULT SCREEN ── -->
    <div id="quizResult" style="display:none;">
        <div class="result-card">
            <div class="result-emoji" id="resultEmoji">🎉</div>
            <h2 class="result-title" id="resultTitle">Sesi Selesai!</h2>
            <p class="result-sub"  id="resultSub"></p>

            <div class="result-stats">
                <div class="rs-item">
                    <span class="rs-num green" id="rCorrect">0</span>
                    <span class="rs-label">benar ✅</span>
                </div>
                <div class="rs-item">
                    <span class="rs-num red" id="rWrong">0</span>
                    <span class="rs-label">salah ❌</span>
                </div>
                <div class="rs-item">
                    <span class="rs-num" id="rXP">+0</span>
                    <span class="rs-label">XP ⭐</span>
                </div>
            </div>

            <!-- Wrong answers review -->
            <div id="wrongReview" style="display:none;">
                <p class="review-title">📖 yang tadi salah:</p>
                <div class="review-list" id="reviewList"></div>
            </div>

            <div class="result-actions">
                <button class="result-btn primary" onclick="startQuiz()">🔄 main lagi</button>
                <button class="result-btn"         onclick="showQuizHome()">🏠 home</button>
            </div>
        </div>
    </div>

</div>

<!-- Panel overlay -->
<div class="panel-overlay" id="panelOverlay" onclick="closeAllPanels()"></div>

<script src="scripts.js"></script>
</body>
</html>
